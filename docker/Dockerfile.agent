FROM python:3.12-slim

LABEL maintainer="prometheus-agent"
LABEL description="Prometheus main agent runtime container"

# Install Docker CLI (official), git, curl, and Playwright system deps
# Note: docker.io only provides dockerd (daemon), not the CLI binary.
# We download the official static Docker CLI binary directly.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        # Playwright/Chromium system dependencies
        libnss3 \
        libatk-bridge2.0-0 \
        libdrm2 \
        libxkbcommon0 \
        libgbm1 \
        libasound2 \
    && rm -rf /var/lib/apt/lists/* \
    && DOCKER_VERSION=27.5.1 \
    && curl -fsSL "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_VERSION}.tgz" \
       | tar xz --strip-components=1 -C /usr/local/bin docker/docker \
    && chmod +x /usr/local/bin/docker

WORKDIR /app

# Install Python deps first (better layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browser (Chromium only — minimal footprint)
RUN playwright install chromium

# Copy source
COPY . .

# Create runtime directories
RUN mkdir -p logs workspace/source_code workspace/versions memory

# Non-root user — but must be in docker group to use the socket
RUN groupadd -f docker \
    && useradd -r -G docker -m agent \
    && chown -R agent:agent /app

USER agent

# Allow agent to use the mounted host git repo
RUN git config --global --add safe.directory /app

ENTRYPOINT ["python", "main.py"]
