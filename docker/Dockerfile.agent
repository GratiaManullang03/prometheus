FROM python:3.12-slim

LABEL maintainer="prometheus-agent"
LABEL description="Prometheus main agent runtime container"

# Install Docker CLI, git, curl, and Playwright system deps
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        docker.io \
        git \
        curl \
        # Playwright/Chromium system dependencies
        libnss3 \
        libatk-bridge2.0-0 \
        libdrm2 \
        libxkbcommon0 \
        libgbm1 \
        libasound2 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (better layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browser (Chromium only — minimal footprint)
RUN playwright install chromium

# Copy source
COPY . .

# Create runtime directories
RUN mkdir -p logs workspace/source_code workspace/versions memory

# Non-root user — but must be in docker group to use the socket
RUN groupadd -f docker \
    && useradd -r -G docker -m agent \
    && chown -R agent:agent /app

USER agent

ENTRYPOINT ["python", "main.py"]
