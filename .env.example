# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Google AI Studio (PRIMARY — gratis, dapat di https://aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here

# OpenRouter (BACKUP — tidak digunakan secara default, bisa diaktifkan di config.yaml)
OPENROUTER_API_KEY=your_openrouter_api_key_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
