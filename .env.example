# Copy this file to .env and fill in your values
# NEVER commit .env to version control

OPENROUTER_API_KEY=your_openrouter_api_key_here

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: SerpAPI key for richer web search results
# Leave empty to fall back to DuckDuckGo Lite (free, no key needed)
SERP_API_KEY=

# Optional: override the agent workspace path (default: ./workspace/source_code)
AGENT_WORKSPACE=./workspace/source_code
